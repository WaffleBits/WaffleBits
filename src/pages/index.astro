---
import Base from "../layouts/Base.astro";
import {
  identity, requestPath, caseFiles, evidence,
  serviceRecord, capability, awards, certifications, education, bootLog,
} from "../data/portfolio";

const ps = `${identity.handle}@${identity.host}:~$`;
const slug = (u: string) => u.split("/").pop() || "case";
const evDir: Record<string, string> = { BNCH: "/benchmarks", RPLY: "/replay-fixtures", TRCE: "/traces", DASH: "/dashboards", GATE: "/promotion-gates", AUDT: "/runbooks-audit" };
const evRoles: Record<string, string> = { BNCH: "ai", RPLY: "ai", TRCE: "ai security", DASH: "security ai", GATE: "ai", AUDT: "security mission" };
const capRoles: Record<string, string> = { AI: "ai", SEC: "security", OBS: "ai security", SYS: "ai mission", OPS: "security mission", LNG: "ai security mission" };
const svcRoles = ["security mission", "ai security mission"];

const metrics = [
  { id: "01", k: "enterprise_terrain", v: "$1.3B", note: "cyber dashboard environment monitored" },
  { id: "02", k: "threat_resolution_cycle", v: "5d > 2d", note: "dashboard + tracking workflow engineering" },
  { id: "03", k: "urgent_change_execution", v: "21d > 5d", note: "combat-readiness exercise support" },
  { id: "04", k: "assets_hardened", v: "30K", note: "18 AFCYBER tasking orders" },
];
---

<Base>
  <div id="live" class="sr-only" aria-live="polite"></div>
  <canvas id="matrix" aria-hidden="true"></canvas>

  <!-- ===== SENTINEL LOADER ===== -->
  <div id="boot" class="boot" role="dialog" aria-label="Sentinel loading sequence" aria-hidden="true" hidden>
    <div class="boot__inner">
      <pre id="boot-eye" class="boot__eye" aria-hidden="true"></pre>
      <p class="boot__title">SENTINEL // OBSERVABILITY CORE</p>
      <pre id="boot-bar" class="boot__bar" aria-hidden="true"></pre>
      <ul id="boot-loadlog" class="boot__log" aria-hidden="true"></ul>
      <p id="boot-cue" class="boot__cue">
        scroll to enter
        <span class="chev" aria-hidden="true">▼</span>
      </p>
    </div>
    <div class="boot__scan" aria-hidden="true"></div>
  </div>

  <header class="status" id="top">
    <span class="seg"><b>{identity.handle}</b><span style="opacity:.7">@{identity.host}</span></span>
    <span class="seg grow hideS"><span id="spin" class="spin" aria-hidden="true">|</span> session://active :: secure-ai-infrastructure</span>
    <span class="seg"><span class="clk" id="clk">--:--:--</span></span>
    <span class="seg"><button class="tok" style="color:inherit" data-open-palette aria-haspopup="dialog" aria-controls="palette">cmd ⌘K</button></span>
  </header>

  <main class="term" id="main">

    <!-- ===== HERO / boot ===== -->
    <section class="op" data-hero>
      <pre id="hero-eye" class="hero__eye" aria-hidden="true"></pre>
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd">boot sentinel --observe</span></p>
      <ul id="boot-log" style="list-style:none;margin:6px 0 14px;padding:0">
        {bootLog.map((b) => (
          <li data-line><span class="ok">▸</span> {b.lbl} <span class="fl">::</span> <span class="ok">{b.val}</span></li>
        ))}
      </ul>
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>load identity.profile</span></p>
      <div id="hero-identity" class="hero__id">
        <p data-line><span class="name">{identity.name}</span> <span class="fl">::</span> <span class="role">{identity.role}</span></p>
        <p data-line style="color:var(--faint)">alias <span class="fl">::</span> {identity.alias} <span class="fl">//</span> loc <span class="fl">::</span> {identity.location} <span class="fl">//</span> open <span class="fl">::</span> {identity.open}</p>
        <p data-line class="tags">{identity.clearance} cleared <span class="fl">//</span> Security+ <span class="fl">//</span> {identity.domains.slice(0, 3).join(" · ")}</p>
        <p data-line class="sum">{identity.summary}</p>
        <p data-line class="tokrow"><span class="lbl">goto::</span>
          <a class="tok" href="#impact">impact</a><a class="tok" href="#request">trace</a><a class="tok" href="#files">cases</a><a class="tok" href="#evidence">evidence</a><a class="tok" href="#service">service</a><a class="tok" href="#capability">capability</a><a class="tok" href="#contact">contact</a>
        </p>
        <p data-line class="tokrow rolepick"><span class="lbl">view::</span>
          <button class="tok on" data-role="all">full</button><button class="tok" data-role="ai">ai_infra</button><button class="tok" data-role="security">platform_sec</button><button class="tok" data-role="mission">mission_eng</button><button class="tok" data-role="recruiter">recruiter</button>
        </p>
      </div>
    </section>

    <!-- ===== MISSION IMPACT ===== -->
    <section class="op" data-op id="impact">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>query mission_impact --public-safe</span></p>
      <div class="op__out recs" data-out>
        {metrics.map((m) => (
          <div class="rec" data-line>
            <span class="id">[{m.id}]</span><span class="k">{m.k}</span><span class="v">{m.v}</span>
            <span class="note">{m.note}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== REQUEST PATH ===== -->
    <section class="op" data-op id="request">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>trace inference_request --inspect</span></p>
      <div class="op__out" data-out data-gap="70">
        <div class="trace" id="trace" role="list">
          {requestPath.map((s, i) => (
            <button class="tl" data-line data-stage={s.id} role="listitem">
              <span class="br">{i === requestPath.length - 1 ? "└─" : "├─"}</span>
              <span class="sq">{s.seq}</span>
              <span class="nm">{s.name}</span>
              <span class="mt">{s.meta}</span>
            </button>
          ))}
        </div>
        <div class="trace__ctl" data-line>
          <button class="tok" id="trace-run">run trace</button>
          <button class="tok" id="trace-fault">inject fault</button>
        </div>
        <div class="trace__out" id="trace-out" data-line aria-live="polite"><span class="k">&gt;&gt;</span> <span class="t">{requestPath[0].name}</span>{"\n   "}{requestPath[0].body}</div>
      </div>
    </section>

    <!-- ===== CASE FILES ===== -->
    <section class="op" data-op id="files">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>ls /case-files && inspect &lt;file&gt;</span></p>
      <div class="op__out" data-out data-gap="60">
        {caseFiles.map((cf, i) => (
          <details class="fentry" id={`case-${cf.id}`} data-line data-roles={cf.roles}>
            <summary>
              <span class="fid">{String(i + 1).padStart(2, "0")}</span>
              <span class="fname">{slug(cf.url)}.case</span>
              <span class="ftags">{cf.tags.join(" ")}</span>
            </summary>
            <div class="finspect">
              <dl>
                <div class="blk"><dt>problem</dt><dd>{cf.problem}</dd></div>
                <div class="blk"><dt>system</dt><dd>{cf.system}</dd></div>
                <div class="blk"><dt>evidence</dt><dd>{cf.evidence}</dd></div>
                <div class="blk"><dt>impact</dt><dd>{cf.impact}</dd></div>
              </dl>
              <a class="tok repo" href={cf.url} target="_blank" rel="noreferrer">open repository</a>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ===== EVIDENCE LOCKER ===== -->
    <section class="op" data-op id="evidence">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>mount /evidence-locker --readonly</span></p>
      <div class="op__out" data-out data-gap="55">
        {evidence.map((ev) => (
          <details class="eentry" data-line data-roles={evRoles[ev.code]}>
            <summary>
              <span class="eid">{ev.code}</span>
              <span class="ename">{evDir[ev.code]}</span>
              <span class="emeta">{String(ev.items.length).padStart(2, "0")} records</span>
            </summary>
            <div class="ebody">
              {ev.items.map((it) => <div data-line>{it}</div>)}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ===== SERVICE RECORD ===== -->
    <section class="op" data-op id="service">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>read service_record.log</span></p>
      <div class="op__out log" data-out data-gap="42">
        {serviceRecord.map((r, i) => (
          <>
            <div data-line data-roles={svcRoles[i]}>
              <span class="ts">[{r.span}]</span>
              <span class="hd"><span class="org">{r.org}</span> :: {r.role}<br />{r.unit}</span>
            </div>
            {r.lines.map((l) => (
              <div data-line data-roles={svcRoles[i]}><span class="ts">  ·</span><span>{l}</span></div>
            ))}
          </>
        ))}
      </div>
    </section>

    <!-- ===== CAPABILITY MATRIX ===== -->
    <section class="op" data-op id="capability">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>query capability_matrix</span></p>
      <div class="op__out recs" data-out data-gap="46">
        {capability.map((c) => (
          <div class="rec two" data-line data-roles={capRoles[c.code]}>
            <span class="id">{c.code}</span><span class="k2">{c.title}</span>
            <span class="note">{c.items}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== RECOGNITION ===== -->
    <section class="op" data-op id="recognition">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>ls /recognition -la</span></p>
      <div class="op__out" data-out data-gap="34">
        <div data-line><span class="cy">awards/</span></div>
        {awards.map((a) => <div data-line><span class="fl">  ·</span> {a}</div>)}
        <div data-line><span class="cy">certifications/</span></div>
        {certifications.map((c) => <div data-line><span class="fl">  ·</span> {c}</div>)}
        <div data-line><span class="cy">education/</span></div>
        {education.map((e) => <div data-line><span class="fl">  ·</span> {e}</div>)}
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section class="op" data-op id="contact">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>open outbound_channel</span></p>
      <div class="op__out" data-out data-gap="40">
        <div class="contact">
          <div class="contact__eye" aria-hidden="true"><pre id="contact-eye"></pre></div>
          <div>
            <p data-line><span class="fl">endpoint</span> <span class="hl">{identity.name}</span> <span class="fl">::</span> channel <span class="ok">open</span></p>
            <p data-line>best reached on LinkedIn; every system here is open on GitHub, so read the code and judge the work directly.</p>
            <p data-line class="tokrow">
              <a class="tok" href={identity.links.linkedin} target="_blank" rel="noreferrer">linkedin</a>
              <a class="tok" href={identity.links.github} target="_blank" rel="noreferrer">github</a>
            </p>
            <p data-line style="color:var(--faint)">{ps} <span class="prompt-cur"></span></p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- ===== COMMAND PALETTE ===== -->
  <div id="palette" class="palette" role="dialog" aria-modal="true" aria-label="Command palette" hidden>
    <div class="palette__box">
      <div class="palette__bar"><span class="u">{identity.handle}</span><span class="host">@{identity.host}</span><span class="ps">:~$ command</span></div>
      <div class="palette__inp">
        <span class="p">&gt;_</span>
        <input id="palette-input" type="text" autocomplete="off" spellcheck="false" placeholder="open · goto · view · contact" aria-label="Command input" />
        <kbd>esc</kbd>
      </div>
      <ul id="palette-list" class="palette__list" role="listbox" aria-label="Commands"></ul>
      <p class="palette__hint">↑↓ navigate · ↵ run · esc close</p>
    </div>
  </div>
</Base>
