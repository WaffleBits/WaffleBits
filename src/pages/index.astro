---
import Base from "../layouts/Base.astro";
import {
  identity, requestPath, caseFiles, proof,
  serviceRecord, capability, awards, certifications, education,
} from "../data/portfolio";

const ps = `${identity.handle}@${identity.host}:~$`;
const capRoles: Record<string, string> = { AI: "ai", SEC: "security", OBS: "ai security", SYS: "ai mission", OPS: "security mission", LNG: "ai security mission" };
const svcRoles = ["security mission", "ai security mission"];
const resumeHref = `${import.meta.env.BASE_URL}assets/AdnanBerik-Resume.pdf`;

const metrics = [
  { id: "01", k: "network_defended", v: "$1.3B", note: "value of the Air Force network environment I helped monitor and defend" },
  { id: "02", k: "threat_fix_time", v: "5d > 2d", note: "how much faster threats got resolved after I built the tracking dashboards" },
  { id: "03", k: "urgent_changes", v: "21d > 5d", note: "urgent network changes sped up during a major combat exercise" },
  { id: "04", k: "systems_hardened", v: "30K", note: "computers and systems hardened against attack, leading 11 Airmen" },
];
---

<Base>
  <div id="live" class="sr-only" aria-live="polite"></div>

  <!-- ===== IDENTITY STRIP (always visible, above loader, never animated) ===== -->
  <div class="idbar" id="idbar">
    <span class="idbar__who"><b>{identity.name}</b><span class="sep"> :: </span>Platform Security &amp; AI Infrastructure<span class="sep"> :: </span>{identity.clearance}</span>
    <span class="idbar__links">
      <a class="tok" href={resumeHref} target="_blank" rel="noreferrer">resume</a>
      <a class="tok" href={identity.links.linkedin} target="_blank" rel="noreferrer">linkedin</a>
      <a class="tok" href={identity.links.github} target="_blank" rel="noreferrer">github</a>
      <a class="tok" href={`mailto:${identity.links.email}`}>email</a>
    </span>
  </div>

  <canvas id="matrix" aria-hidden="true"></canvas>

  <!-- ===== SENTINEL LOADER ===== -->
  <div id="boot" class="boot" role="dialog" aria-label="Sentinel loading sequence" aria-hidden="true" hidden>
    <div class="boot__inner">
      <pre id="boot-eye" class="boot__eye" aria-hidden="true"></pre>
      <p class="boot__title">SENTINEL // OBSERVABILITY CORE</p>
      <pre id="boot-bar" class="boot__bar" aria-hidden="true"></pre>
      <ul id="boot-loadlog" class="boot__log" aria-hidden="true"></ul>
      <p id="boot-cue" class="boot__cue">
        scroll to enter
        <span class="chev" aria-hidden="true">▼</span>
        <button class="tok boot__fast" type="button" id="boot-recruiter">recruiter view</button>
      </p>
    </div>
    <div class="boot__scan" aria-hidden="true"></div>
  </div>

  <header class="status" id="top">
    <span class="seg"><b>{identity.handle}</b><span style="opacity:.7">@{identity.host}</span></span>
    <span class="seg grow hideS"><span id="spin" class="spin" aria-hidden="true">|</span> session://active :: secure-ai-infrastructure</span>
    <span class="seg"><span class="clk" id="clk">--:--:--</span></span>
    <span class="seg"><button class="tok" style="color:inherit" data-open-palette aria-haspopup="dialog" aria-controls="palette">cmd ⌘K</button></span>
  </header>

  <main class="term" id="main">

    <!-- ===== HERO ===== -->
    <section class="op" data-hero>
      <pre id="hero-eye" class="hero__eye" aria-hidden="true"></pre>
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>load identity.profile</span><span class="plain">About</span></p>
      <div id="hero-identity" class="hero__id">
        <p data-line><span class="name">{identity.name}</span> <span class="fl">::</span> <span class="role">{identity.role}</span></p>
        <p data-line class="tagline">{identity.tagline}</p>
        <p data-line class="sum">{identity.summary}</p>
        <p data-line class="sum plainbox"><span class="acc">in plain terms ::</span> {identity.plain}</p>
        <p data-line style="color:var(--faint)">{identity.location} <span class="fl">//</span> open to {identity.open} <span class="fl">//</span> <a class="tok" href={resumeHref} target="_blank" rel="noreferrer">resume.pdf</a></p>
        <p data-line class="tokrow"><span class="lbl">goto::</span>
          <a class="tok" href="#impact">impact</a><a class="tok" href="#request">how it works</a><a class="tok" href="#files">projects</a><a class="tok" href="#evidence">proof</a><a class="tok" href="#service">experience</a><a class="tok" href="#contact">contact</a>
        </p>
        <p data-line class="tokrow rolepick"><span class="lbl">view::</span>
          <button class="tok on" data-role="all">everything</button><button class="tok" data-role="ai">ai_infra</button><button class="tok" data-role="security">security</button><button class="tok" data-role="mission">mission</button><button class="tok" data-role="recruiter">recruiter</button>
        </p>
      </div>
    </section>

    <!-- ===== IMPACT ===== -->
    <section class="op" data-op id="impact">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>query impact --summary</span><span class="plain">Impact highlights</span></p>
      <div class="op__out recs" data-out>
        <p data-line class="secintro">Numbers from my Air Force cyber defense work. Each one is on my resume and stands up to questions.</p>
        {metrics.map((m) => (
          <div class="rec" data-line>
            <span class="id">[{m.id}]</span><span class="k">{m.k}</span><span class="v">{m.v}</span>
            <span class="note">{m.note}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== REQUEST PATH ===== -->
    <section class="op" data-op id="request">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>trace one_ai_request</span><span class="plain">How my work fits together</span></p>
      <div class="op__out" data-out data-gap="70">
        <p data-line class="secintro">This is the layer I build, shown as one AI request passing through it. Click any stage, or <span class="hl">run the trace</span> and watch it catch a failure.</p>
        <div class="trace" id="trace" role="list">
          {requestPath.map((s, i) => (
            <button class="tl" data-line data-stage={s.id} role="listitem">
              <span class="br">{i === requestPath.length - 1 ? "└─" : "├─"}</span>
              <span class="sq">{s.seq}</span>
              <span class="nm">{s.name}</span>
              <span class="mt">{s.meta}</span>
            </button>
          ))}
        </div>
        <div class="trace__ctl" data-line>
          <button class="tok" id="trace-run">run trace</button>
          <button class="tok" id="trace-fault">inject fault</button>
        </div>
        <div class="trace__out" id="trace-out" data-line aria-live="polite"><span class="k">&gt;&gt;</span> <span class="t">{requestPath[0].name}</span>{"\n   "}{requestPath[0].body}</div>
      </div>
    </section>

    <!-- ===== PROJECTS ===== -->
    <section class="op" data-op id="files">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>ls /projects</span><span class="plain">Projects</span></p>
      <div class="op__out" data-out data-gap="60">
        <p data-line class="secintro">Seven systems, all public on GitHub. One plain sentence each; open <span class="hl">inspect</span> for the engineering detail.</p>
        {caseFiles.map((cf, i) => (
          <div class="fwrap" data-line data-roles={cf.roles}>
            <details class="fentry" id={`case-${cf.id}`}>
              <summary>
                <span class="fid">{String(i + 1).padStart(2, "0")}</span>
                <span class="fname">{cf.title}</span>
                <span class="ftags">{cf.tags.join(" · ")}</span>
              </summary>
              <div class="finspect">
                <dl>
                  <div class="blk"><dt>problem</dt><dd>{cf.problem}</dd></div>
                  <div class="blk"><dt>built</dt><dd>{cf.system}</dd></div>
                  <div class="blk"><dt>proof</dt><dd>{cf.evidence}</dd></div>
                  <div class="blk"><dt>result</dt><dd>{cf.impact}</dd></div>
                </dl>
              </div>
            </details>
            <p class="fplain">{cf.plain}</p>
            <p class="flinks">
              {cf.demo && <a class="tok demo" href={cf.demo} target="_blank" rel="noreferrer">live demo</a>}
              {cf.chart && <a class="tok" href={cf.chart} target="_blank" rel="noreferrer">see the chart</a>}
              <a class="tok" href={cf.url} target="_blank" rel="noreferrer">source code</a>
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== PROOF ===== -->
    <section class="op" data-op id="evidence">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>ls /proof</span><span class="plain">Proof, not promises</span></p>
      <div class="op__out" data-out data-gap="55">
        <p data-line class="secintro">Everything above is checkable. These links go straight to the artifacts.</p>
        {proof.map((p) => (
          <div class="prow" data-line>
            <span class="pkind">[{p.kind}]</span>
            <a class="tok" href={p.href} target="_blank" rel="noreferrer">{p.label}</a>
            <span class="pplain">{p.plain}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== EXPERIENCE ===== -->
    <section class="op" data-op id="service">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>read service_record.log</span><span class="plain">Experience</span></p>
      <div class="op__out log" data-out data-gap="42">
        {serviceRecord.map((r, i) => (
          <>
            <div data-line data-roles={svcRoles[i]}>
              <span class="ts">[{r.span}]</span>
              <span class="hd"><span class="org">{r.org}</span> :: {r.role}<br />{r.unit}</span>
            </div>
            {r.lines.map((l) => (
              <div data-line data-roles={svcRoles[i]}><span class="ts">  ·</span><span>{l}</span></div>
            ))}
          </>
        ))}
      </div>
    </section>

    <!-- ===== SKILLS ===== -->
    <section class="op" data-op id="capability">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>query capability</span><span class="plain">What I can do for you</span></p>
      <div class="op__out recs" data-out data-gap="46">
        {capability.map((c) => (
          <div class="rec two caprow" data-line data-roles={capRoles[c.code]}>
            <span class="id">{c.code}</span><span class="k2">{c.title}</span>
            <span class="note"><span class="capplain">{c.plain}</span><br /><span class="captech">{c.items}</span></span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== RECOGNITION ===== -->
    <section class="op" data-op id="recognition">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>ls /recognition</span><span class="plain">Awards and education</span></p>
      <div class="op__out" data-out data-gap="34">
        <div data-line><span class="cy">awards/</span></div>
        {awards.map((a) => <div data-line><span class="fl">  ·</span> {a}</div>)}
        <div data-line><span class="cy">certifications/</span></div>
        {certifications.map((c) => <div data-line><span class="fl">  ·</span> {c}</div>)}
        <div data-line><span class="cy">education/</span></div>
        {education.map((e) => <div data-line><span class="fl">  ·</span> {e}</div>)}
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section class="op" data-op id="contact">
      <p class="op__cmd"><span class="ps">{ps}</span> <span class="cmd" data-type>open outbound_channel</span><span class="plain">Contact</span></p>
      <div class="op__out" data-out data-gap="40">
        <div class="contact">
          <div class="contact__eye" aria-hidden="true"><pre id="contact-eye"></pre></div>
          <div>
            <p data-line><span class="fl">endpoint</span> <span class="hl">{identity.name}</span> <span class="fl">::</span> channel <span class="ok">open</span></p>
            <p data-line>If you are hiring for AI infrastructure, platform security, or mission software, I would like to talk.</p>
            <p data-line class="tokrow">
              <a class="tok" href={`mailto:${identity.links.email}`}>{identity.links.email}</a>
              <a class="tok" href={identity.links.linkedin} target="_blank" rel="noreferrer">linkedin</a>
              <a class="tok" href={identity.links.github} target="_blank" rel="noreferrer">github</a>
              <a class="tok" href={resumeHref} target="_blank" rel="noreferrer">resume.pdf</a>
            </p>
            <p data-line style="color:var(--faint)">{ps} <span class="prompt-cur"></span></p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- ===== COMMAND PALETTE ===== -->
  <div id="palette" class="palette" role="dialog" aria-modal="true" aria-label="Command palette" hidden>
    <div class="palette__box">
      <div class="palette__bar"><span class="u">{identity.handle}</span><span class="ps">@</span><span class="host">{identity.host}</span><span class="ps">:~$ command</span></div>
      <div class="palette__inp">
        <span class="p">&gt;_</span>
        <input id="palette-input" type="text" autocomplete="off" spellcheck="false" placeholder="open · goto · view · contact" aria-label="Command input" />
        <kbd>esc</kbd>
      </div>
      <ul id="palette-list" class="palette__list" role="listbox" aria-label="Commands"></ul>
      <p class="palette__hint">↑↓ navigate · ↵ run · esc close</p>
    </div>
  </div>
</Base>
