---
interface Props { seq: string; label: string; tag?: string; id?: string; }
const { seq, label, tag, id } = Astro.props;
---
<div class="frame" id={id}>
  <div class="frame__bar">
    <span class="frame__seq">[{seq}]</span>
    <span class="frame__label" data-reveal="scramble">{label}</span>
    {tag && <span class="frame__tag">{tag}</span>}
  </div>
  <div class="frame__body"><slot /></div>
</div>
