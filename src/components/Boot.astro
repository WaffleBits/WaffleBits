---
import { bootLog } from "../data/portfolio";
---
<div id="boot" class="boot" role="dialog" aria-label="System boot sequence" aria-hidden="true" hidden>
  <div class="boot__inner">
    <pre id="boot-eye" class="boot__eye" aria-hidden="true"></pre>
    <p class="boot__title">SENTINEL // OBSERVABILITY CORE</p>
    <ul id="boot-log" class="boot__log" aria-hidden="true">
      {bootLog.map((b) => (
        <li><span class="ok">▸</span><span class="lbl">{b.lbl}</span><span class="val">{b.val}</span></li>
      ))}
    </ul>
  </div>
  <button id="boot-skip" class="boot__skip" type="button">skip <kbd>esc</kbd></button>
  <div class="boot__scan" aria-hidden="true"></div>
</div>
