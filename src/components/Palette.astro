---
import { identity } from "../data/portfolio";
---
<div id="palette" class="palette" role="dialog" aria-modal="true" aria-label="Command palette" hidden>
  <div class="palette__box">
    <div class="palette__bar"><span class="u">{identity.handle}</span><span class="ps">@</span><span class="host">{identity.host}</span><span class="ps">:~$ command</span></div>
    <div class="palette__inp">
      <span class="p">&gt;_</span>
      <input id="palette-input" type="text" autocomplete="off" spellcheck="false" placeholder="open · goto · view · contact" aria-label="Command input" />
      <kbd>esc</kbd>
    </div>
    <ul id="palette-list" class="palette__list" role="listbox" aria-label="Commands"></ul>
    <p class="palette__hint">↑↓ navigate · ↵ run · esc close</p>
  </div>
</div>
